{
  "manifest_version": 3,
  "name": "Jesty",
  "version": "2.1.1",
  "description": "Meet Jesty! The companion you need that roasts your browsing, keeps you focused, and rewards you with games and collectibles.",
  "permissions": ["tabs", "storage", "sidePanel", "alarms", "scripting"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["focus-content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["focus-island.html", "focus-island.css", "focus-island.js", "characters.js", "theme.js"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}
